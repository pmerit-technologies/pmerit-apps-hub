# All pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; worker-src 'self'; manifest-src 'self'

# Cache static assets aggressively (hashed filenames = immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker must not be cached
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Workbox runtime
/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest — cache 1 day
/manifest.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

# registerSW — must not be cached (triggers SW updates)
/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML — revalidate always
/index.html
  Cache-Control: no-cache
